//Declarando uma função chamada criarArquivoInicial

void criarArquivoInicial() {

   

  FILE *arquivo = fopen("mercearia.txt", "w"); // Esta sendo criado um ponteiro chamado arquivo que esta apontando para mercenaria.txt no modo escrito, isso quer dizer que se ele nao existir ele vai criar.

   

  // Se o ponteiro 'arquivo' for NULL, significa que deu problema e o arquivo não abriu

  if (arquivo == NULL) {

    printf(COR_ERRO "Erro ao criar arquivo!\n" RESET); // Avisa com cor vermelha que deu erro.

    return; // Sai da função

  }



  //Está sendo criado um vetor chamado lista, do tipo Produto, que armazena vários produtos com valores correspondentes aos seus respectivos campos.

  Produto lista[] = {

    // ID, Nome, Categoria, Preço, Quantidade, Fornecedor

    {1, "Arroz Branco 5kg", "Cereais", 22.90, 50, "Alimentos do Sul"},

    {2, "Feijao Carioca 1kg", "Cereais", 8.75, 60, "Campo Bom"},

    {3, "Açucar Refinado 1kg", "Mercearia", 4.99, 80, "Doce Vida"},

    {4, "Café Torrado 500g", "Bebidas", 18.50, 40, "Sabor Mineiro"},

    {5, "Macarrão Espaguete 500g", "Massas", 5.20, 100, "Massa Boa"},

    {6, "Óleo de Soja 900ml", "Mercearia", 6.49, 75, "RefinaBrasil"},

    {7, "Sal Refinado 1kg", "Mercearia", 3.29, 120, "Salina Real"},

    {8, "Leite Integral 1L", "Laticínios", 5.99, 90, "Lactosul"},

    {9, "Biscoito Recheado 140g", "Biscoitos", 3.49, 200, "Delicia Pura"},

    {10, "Farinha de Trigo 1kg", "Panificação", 6.79, 65, "Moinho Fino"}

  };



  // Um loop que passa por todos os 10 produtos da lista.

  for (int i = 0; i < 10; i++) {

    // 'fprintf' escreve no arquivo, igual ao 'printf' que imprime na tela

    // Ele coloca as informações do produto separadas por ';' 

    // e um '\n' no final usado par quebrar a linha

    fprintf(arquivo, "%d;%s;%s;%.2f;%d;%s\n", //OBS: %.2f e 2 numeros depois da virgula

     

        lista[i].id, lista[i].nome, lista[i].categoria, //essa linha está acessando os campos da struct Produto que estão dentro do elemento i do vetor lista.

        lista[i].preco, lista[i].quantidade, lista[i].fornecedor); //O i indica qual produto do vetor está sendo acessado, e os nomes após o ponto indicam quais informações desse produto estão sendo gravadas no arquivo.

  }



  fclose(arquivo); // 'Fecha' o arquivo. 

  printf(COR_OK "Arquivo 'mercearia.txt' criado com sucesso!\n" RESET); // Avisa com cor verde que deu tudo certo.

}



// Lê o arquivo e carrega os produtos no vetor 

// Essa função vai ler o que está no arquivo e colocar dentro da lista produtos[].

int lerArquivo(Produto produtos[]) {

  // Tenta abrir o arquivo no modo 'r' (read, para ler)

   

  FILE *arquivo = fopen("mercearia.txt", "r"); // Um ponteiro chamado arquivo que esta abrindo mercenaria.txt no modo leitura

   

  // Se não conseguir abrir, o arquivo não existe ou deu erro.

  if (arquivo == NULL) { // Se o arquivo estiver vazio

    printf(COR_ERRO "Arquivo não encontrado! Crie o arquivo primeiro.\n" RESET); // Imprime na tela essa mensagem para o usuario

    return 0; // Devolve 0, dizendo que não leu nenhum produto.

  }



  int total = 0; // Um contador para saber quantos produtos já leu, começa em 0

  char linha[200]; // Uma variável chamada linha que suporta ate 200 caracteres para guardar cada linha inteira lida do arquivo.



  // 'fgets' lê uma linha inteira do arquivo por vez. O loop continua enquanto ele conseguir ler uma linha.

  while (fgets(linha, sizeof(linha), arquivo)) { // serve para ler a linha de um texto de um arquvio e armazenar numa string que seria vetor de char

    // 'sscanf' é o 'scanf' para strings Ele lê a 'linha' inteira e tenta separar as informações.

    // %d;%49[^;]... são 'regras' para separar:

    // - %d: um número (para o ID e Quantidade)

    // - %f: um número com vírgula (para o Preço)

    // - %49[^;]: um texto (Nome e Fornecedor), que pega até 49 letras e para quando encontra um ';' .

    sscanf(linha, "%d;%49[^;];%29[^;];%f;%d;%49[^\n]",

        &produtos[total].id,

        produtos[total].nome,

        produtos[total].categoria,

        &produtos[total].preco,

        &produtos[total].quantidade,

        produtos[total].fornecedor);

    total++; // Aumenta o contador para o próximo produto.

  }



  fclose(arquivo); // Fecha o arquivo.

  return total; // Devolve a quantidade total de produtos que foram lidos.

}



// === Exibe os produtos em formato de tabela ===

void mostrarProdutos(Produto produtos[], int total) {

  // Imprime o cabeçalho da tabela com o título em amarelo.

  // %-5s, %-25s... são 'regras de formatação' que garantem que o texto (s) fique alinhado à esquerda (-) e ocupe um certo espaço (5, 25, 15...).

  printf(COR_TITULO "\n%-5s %-25s %-15s %-10s %-10s %-20s\n" RESET,

      "ID", "Produto", "Categoria", "Preço", "Qtde", "Fornecedor");

      

  // Imprime uma linha de separação azul.

  printf(COR_AZUL "-------------------------------------------------------------------------------\n" RESET);



  // Passa por todos os produtos lidos ('total') e imprime a linha de cada um.

  for (int i = 0; i < total; i++) {

    // %-10.2f é para o Preço: alinhado à esquerda, ocupa 10 espaços e mostra SEMPRE 2 casas depois da vírgula (.2f).

    printf("%-5d %-25s %-15s %-10.2f %-10d %-20s\n",

        produtos[i].id, produtos[i].nome, produtos[i].categoria,

        produtos[i].preco, produtos[i].quantidade, produtos[i].fornecedor);

  }

}



// Salva o vetor de produtos no arquivo 





// pegando a função salvarAquivo e salvando os parametros produtos (vetor) e total do tipo inteiro

void salvarArquivo(Produto produtos[], int total) {

  char opc; // variavel do tipo caracter chamada opc

  printf("\nDeseja salvar a lista ordenada no arquivo (S/N)? ");

  scanf(" %c", &opc); // le a opcao que o usuario digitou na formatação de caracter.



  // 'toupper(opc)' transforma a letra digitada em maiúscula, assim 's' ou 'S' funcionam.

  if (toupper(opc) == 'S') {

    // Abre o arquivo no modo 'w' para sobrescrever (apagar o antigo e escrever o novo).

    FILE *arquivo = fopen("mercearia.txt", "w");

    if (arquivo == NULL) {

      printf(COR_ERRO "Erro ao salvar arquivo!\n" RESET);

      return;

    }



    // Passa por todos os produtos da lista (agora já ordenada).

    for (int i = 0; i < total; i++) {

      // Escreve cada produto no arquivo, com o separador ';' e quebra de linha '\n'.

      fprintf(arquivo, "%d;%s;%s;%.2f;%d;%s\n", // mostrando no arquivo novamente com os seus tipos de dados

          produtos[i].id, produtos[i].nome, produtos[i].categoria, // Esta pegando ID, NOME, PRODUTOS e o que foi guardaodo

          produtos[i].preco, produtos[i].quantidade, produtos[i].fornecedor); // A linha de cima serve para essa

    }



    fclose(arquivo); // fechando o arquivo 

    printf(COR_OK "\nArquivo atualizado com sucesso!\n" RESET); // imprimindo na tela a mensagem + a cor OK e RESET (mandando o terminal voltar para a cor normal)

  } else {

    // Se a opção não for 'S' ou 's'.

    printf(COR_ERRO "\nAlterações descartadas.\n" RESET); // imprimindo na tela a mensagem com a cor ERRO e RESET (mandando o terminal voltar para a cor normal)

  }

}



// Ordena produtos de diferentes formas 



// declarando uma função chamada ordenar com o parametro chamado tipo que e do tipo inteiro

void ordenar(int tipo) {

  Produto produtos[200]; // Cria um vetor chamado produtos que vai armazenar ate 200 caracteres do tipo PRODUTO

  int total = lerArquivo(produtos); // Lê os produtos do arquivo para essa lista.

  if (total == 0) return; // Se não leu nada, sai da função.



  Produto temp; // Uma variável temporária para ajudar a trocar os produtos de lugar.



  // Algoritmo de Ordenação: Bubble Sort 

   

  // Dois loops que comparam e trocam os produtos.

   

  // O loop de fora i garante que a gente compare todos os produtos.

   

  for (int i = 0; i < total - 1; i++) { // ele controla o produto que esta sendo comparado i vai de 0 até total - 2 (porque o último elemento não precisa ser comparado com ele mesmo).



   // Em cada volta do loop, o i representa o produto atual que será comparado com os que vêm depois.

    // O loop de dentro (j) compara o produto 'i' com todos os outros que vêm depois dele.

    for (int j = i + 1; j < total; j++) {

      int trocar = 0; // Uma bandeira que começa em 0 não trocar.



      // tipo(que veio do menu) define a regra de troca:

       

      // Tipo 1: Nome A-Z (Ordem alfabética)

      // strcmp compara dois textos. Se for MAIOR que 0, significa que o primeiro texto (produtos[i].nome)

      // deve vir DEPOIS do segundo (produtos[j].nome), então precisa trocar

      if (tipo == 1 && strcmp(produtos[i].nome, produtos[j].nome) > 0) trocar = 1;

       

      // Tipo 2: Nome Z-A (Ordem alfabética inversa)

      // Se for MENOR que 0, o primeiro texto deve vir ANTES do segundo (na ordem A-Z).

      // Como queremos Z-A, se for menor, a gente troca!

      else if (tipo == 2 && strcmp(produtos[i].nome, produtos[j].nome) < 0) trocar = 1;

       

      // Tipo 3: Preço crescente (menor -> maior)

      // Se o primeiro preço for MAIOR que o segundo, a gente troca.

      else if (tipo == 3 && produtos[i].preco > produtos[j].preco) trocar = 1;

       

      // Tipo 4: Preço decrescente (maior -> menor)

      // Se o primeiro preço for MENOR que o segundo, a gente troca.

      else if (tipo == 4 && produtos[i].preco < produtos[j].preco) trocar = 1;

       

      // Tipo 5: Categoria + Nome

      else if (tipo == 5) {

        int cmp = strcmp(produtos[i].categoria, produtos[j].categoria); // Compara as categorias primeiro.

         

        // Se a categoria do produto 'i' é MAIOR que a do produto 'j' (cmp > 0), troca.

        // OU (||) Se as categorias são IGUAIS (cmp == 0) E o nome do produto 'i' for MAIOR que o 'j' (strcmp(...) > 0), troca.

        if (cmp > 0 || (cmp == 0 && strcmp(produtos[i].nome, produtos[j].nome) > 0))

          trocar = 1;

      }



      // Se 'trocar' for 1 (verdadeiro), a gente faz a troca dos produtos:

      if (trocar) {

        temp = produtos[i];  // Guarda o produto 'i' no coringa.

        produtos[i] = produtos[j]; // Coloca o produto 'j' na posição 'i'.

        produtos[j] = temp;  // Pega o produto que estava no coringa e coloca na posição 'j'.

      }

    }

  }



  printf(COR_OK "\nProdutos ordenados com sucesso!\n" RESET);

  mostrarProdutos(produtos, total); // Mostra o resultado da ordenação.

  salvarArquivo(produtos, total); // Pergunta se quer salvar essa lista ordenada no arquivo.

}



// declarando a função menu principal 

void menu() {

  int opcao;



  do {

    // O do e while garante que o menu rode pelo menos uma vez e fique rodando até a opção ser 0.

    limparTela(); // Limpa a tela para começar o menu.

    printf(COR_TITULO "\nSISTEMA DE MERCEARIA\n" RESET);

    // Exibe todas as opções disponíveis.

    printf("1 - Criar arquivo inicial\n");

    printf("2 - Listar produtos\n");

    printf("3 - Ordenar por nome (A-Z)\n");

    printf("4 - Ordenar por nome (Z-A)\n");

    printf("5 - Ordenar por preço (menor -> maior)\n");

    printf("6 - Ordenar por preço (maior -> menor)\n");

    printf("7 - Ordenar por categoria e nome\n");

    printf("0 - Sair\n");

    printf("-----------------------------------\n");

    printf("Escolha uma opção: ");

    scanf("%d", &opcao); // Lê a opção que o usuário escolheu no formato decimal.



    limparTela(); // Limpa a tela novamente para mostrar a ação escolhida.



    // O switch verifica qual opção foi escolhida e executa o código daquele case.

    switch (opcao) {

      case 1: criarArquivoInicial(); break; // Se for 1, chama a função para criar o arquivo inicial.

      case 2: { // Se for 2, lista os produtos.

        Produto lista[200]; // cria um vetor chamado lista que pode armazenar ate 200 elementos do tipo Produto

        int total = lerArquivo(lista); // Primeiro lê o arquivo.

        if (total > 0) mostrarProdutos(lista, total); // Se leu algum produto, mostra a lista.

        break;

      }

      case 3: ordenar(1); break; // Se for 3, chama 'ordenar' com tipo 1 (Nome A-Z).

      case 4: ordenar(2); break; // Se for 4, chama 'ordenar' com tipo 2 (Nome Z-A).

      case 5: ordenar(3); break; // Se for 5, chama 'ordenar' com tipo 3 (Preço crescente).

      case 6: ordenar(4); break; // Se for 6, chama 'ordenar' com tipo 4 (Preço decrescente).

      case 7: ordenar(5); break; // Se for 7, chama 'ordenar' com tipo 5 (Categoria e Nome).

      case 0: printf(COR_TITULO "Encerrando o programa...\n" RESET); break; // Se for 0, mostra mensagem de saída.

      default: printf(COR_ERRO "Opção inválida!\n" RESET); // Se for qualquer outro número, avisa que está errado.

    }



    // Se a opção NÃO for 0 (Sair), pede para o usuário apertar ENTER.

    if (opcao != 0) {

      printf("\nPressione ENTER para continuar...");

      getchar(); // O primeiro 'getchar' limpa o ENTER que sobrou do 'scanf' da opção.

      getchar(); // O segundo 'getchar' espera que o usuário aperte ENTER de verdade.

    }



  } while (opcao != 0); // O loop continua rodando enquanto a opção for diferente de 0.

}



// Função principal

