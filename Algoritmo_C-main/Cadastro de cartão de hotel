Um projeto de cadastro de hotel.

#include <stdio.h> #include <stdlib.h> #include <string.h>

typedef struct { int idCartao; int quarto; } Cartao;

typedef struct { int idPessoa; nome de caractere[50]; quarto interno; int idCartão; } Pessoa;

//---------------------------------------------------------------------- // CARTÃO CADASTRAR //------------------------------------------------------------ void cadastrarCartao(FILE *arqCartao) { Cartao c;

printf("\n--- Cadastro de Cartão ---\n");
printf("ID do cartão: ");
scanf("%d", &c.idCartao);

printf("Número do quarto: ");
scanf("%d", &c.quarto);

fprintf(arqCartao, "%d;%d\n", c.idCartao, c.quarto);

printf("Cartão cadastrado!\n");
}

//---------------------------------------------------------------------- // LISTAR CARTÕES //------------------------------------------------------------ void listarCartoes(FILE *arqCartao) { Cartao c;

rewind(arqCartao);
printf("\n--- Lista de Cartões ---\n");

while (fscanf(arqCartao, "%d;%d\n", &c.idCartao, &c.quarto) == 2) {
    printf("Cartão ID: %d | Quarto: %d\n", c.idCartao, c.quarto);
}
}

//---------------------------------------------------------------------- // VERIFICAR ACESSO //------------------------------------------------------------ void verificarAcesso(FILE *arqCartao) { Cartao c; int idBusca, quartoBusca;

printf("\n--- Verificar Acesso ---\n");
printf("ID do cartão: ");
scanf("%d", &idBusca);

printf("Quarto que deseja abrir: ");
scanf("%d", &quartoBusca);

rewind(arqCartao);

while (fscanf(arqCartao, "%d;%d\n", &c.idCartao, &c.quarto) == 2) {
    if (c.idCartao == idBusca && c.quarto == quartoBusca) {
        printf("ACESSO PERMITIDO!\n");
        return;
    }
}

printf("ACESSO NEGADO!\n");
}

//---------------------------------------------------------------------- // CADASTRAR PESSOA //------------------------------------------------------------ void cadastrarPessoa(FILE *arqPessoa) { Pessoa p;

printf("\n--- Cadastro de Pessoa ---\n");
printf("ID da pessoa: ");
scanf("%d", &p.idPessoa);

getchar();

printf("Nome: ");
fgets(p.nome, 50, stdin);
p.nome[strcspn(p.nome, "\n")] = '\0';

printf("Quarto: ");
scanf("%d", &p.quarto);

p.idCartao = -1;

fprintf(arqPessoa, "%d;%s;%d;%d\n", p.idPessoa, p.nome, p.quarto, p.idCartao);

printf("Pessoa cadastrada!\n");
}

//---------------------------------------------------------------------- // LISTAR PESSOAS //------------------------------------------------------------ void listarPessoas(FILE *arqPessoa) { Pessoa p;

rewind(arqPessoa);
printf("\n--- Lista de Pessoas ---\n");

while (fscanf(arqPessoa, "%d;%49[^;];%d;%d\n",
              &p.idPessoa, p.nome, &p.quarto, &p.idCartao) == 4) {
    printf("ID: %d | Nome: %s | Quarto: %d | Cartão: %d\n",
           p.idPessoa, p.nome, p.quarto, p.idCartao);
}
}

